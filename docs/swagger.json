                    "type": "integer"
                }
            }
        },
        "connect-to-mongodb_internal_analysis.Notification": {
            "type": "object",
            "properties": {
                "created_at": {
                    "type": "integer"
                },
                "id": {
                    "type": "string"
                },
                "message": {
                    "type": "string"
