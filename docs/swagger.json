            "properties": {
                "activity_description": {
                    "type": "string"
                },
                "activity_name": {
                    "type": "string"
                },
                "date": {},
                "id": {
                    "type": "string"
                },
                "start_time": {
                    "type": "string"
                },
                "time": {}
            }
        },
        "connect-to-mongodb_internal_analysis.ActivityLimit": {
            "type": "object",
            "properties": {
                "activity_name": {
                    "type": "string"
                },
                "limit": {
                    "type": "integer"
                }
            }
        },
        "connect-to-mongodb_internal_analysis.AnalysisReport": {
            "type": "object",
            "properties": {
                "activities": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/connect-to-mongodb_internal_analysis.Activity"
                    }
                },
                "activities_summary_minutes": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "integer"
                    }
                },
                "daily_limits": {
                    "$ref": "#/definitions/connect-to-mongodb_internal_analysis.DailyLimits"
                },
                "date": {
                    "type": "string"
                },
                "exceeded_limits": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    }
                },
                "global_limit": {
                    "type": "string"
                },
                "global_limit_exceeded": {
                    "type": "boolean"
                },
                "login": {
                    "type": "string"
                },
                "notifications": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/connect-to-mongodb_internal_analysis.Notification"
                    }
                },
                "total_duration_minutes": {
                    "type": "integer"
                }
            }
        },
        "connect-to-mongodb_internal_analysis.DailyLimits": {
            "type": "object",
            "properties": {
                "activities": {
                    "type": "array",
